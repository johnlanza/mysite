      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@400" />

    <link
      rel="stylesheet"
      href="https://stackpath.bootstrapcdn.com/bootstrap/4.1.3/css/bootstrap.min.css" />

    <link
      href="https://fonts.cdnfonts.com/css/apple-garamond"
      rel="stylesheet" />

    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&display=swap"
      rel="stylesheet" />

    <link
      rel="stylesheet"
      href="https://use.typekit.net/ceb0zrq.css" />

    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600;700&display=swap"
      rel="stylesheet" />

    <script>
      (function () {
        try {
          const savedIndex = parseInt(
            localStorage.getItem("siteDesignIndex"),
            10
          );
          const design = savedIndex === 1 ? "metro" : "classic";
          document.documentElement.setAttribute("data-design", design);
        } catch (e) {
          document.documentElement.setAttribute("data-design", "classic");
        }
      })();
    </script>

    <link rel="stylesheet" href="/css/app.css" />
    <link
      href="https://cdn.quilljs.com/1.3.7/quill.snow.css"
      rel="stylesheet" />

    <title>John Lanza</title>
  </head>

