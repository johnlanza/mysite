    <div class="container site-shell px-3">
      <div class="row">
        <div class="col">
          <!-- SITE HEADER -->
          <header class="site-header">
            <div class="station-sign">
              <span class="station-code">LA-01</span>
              <span class="station-name">Personal Route Map</span>
              <a
                href="https://www.metro.net/riding/guide/system-maps/"
                target="_blank"
                rel="noopener noreferrer"
                class="metro-map-credit">
                Map source: LA Metro
              </a>
            </div>

            <div class="brand-row">
              <h1>
                <a href="/" class="main-header">John Lanza</a>
              </h1>
              <img
                src="/images/john-portrait.jpg"
                alt="Portrait of John Lanza"
                class="main-header-portrait"
                loading="lazy" />
            </div>

            <!-- SIMPLE TOP NAV (now responsive) -->
            <nav class="simple-nav" aria-label="Primary navigation">
              <a href="/books">
                <span class="line-badge line-badge-a">A</span>
                <span class="nav-label">Book Summaries</span>
              </a>
              <a href="/events">
                <span class="line-badge line-badge-b">B</span>
                <span class="nav-label">Timeline</span>
              </a>
              <a href="/#books-written">
                <span class="line-badge line-badge-e">E</span>
                <span class="nav-label">Writing</span>
              </a>
              <a
                href="https://category6consulting.com/speaker/john-lanza/"
                target="_blank">
                <span class="line-badge line-badge-k">K</span>
                <span class="nav-label">Speaking</span>
              </a>
              <a href="/games">
                <span class="line-badge line-badge-c">C</span>
                <span class="nav-label">Games</span>
              </a>
              <a href="#" id="designs-link">
                <span class="line-badge line-badge-d">D</span>
                <span class="nav-label">Designs</span>
              </a>
            </nav>
          </header>

          <!-- FLASH MESSAGES -->
          <% if (success && success.length > 0) { %>
          <div
            class="alert alert-success alert-dismissible fade show"
            role="alert">
            <%= success %>
            <button type="button" class="close" data-dismiss="alert">
              <span>&times;</span>
            </button>
          </div>
          <% } %> <% if (error && error.length > 0) { %>
          <div
            class="alert alert-danger alert-dismissible fade show"
            role="alert">
            <%= error %>
            <button type="button" class="close" data-dismiss="alert">
              <span>&times;</span>
            </button>
          </div>
          <% } %>

          <main class="site-main" id="main-content"><%- body %></main>
        </div>
      </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.3.1.slim.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.1.3/js/bootstrap.min.js"></script>

    <script>
      (function () {
        const DESIGN_STORAGE_KEY = "siteDesignIndex";
        const DESIGNS = [
          { name: "classic", label: "Classic" },
          { name: "metro", label: "Metro" },
        ];

        let currentDesignIndex = 0;
        let designsLink = null;

        function getStoredDesignIndex() {
          try {
            const parsed = parseInt(
              localStorage.getItem(DESIGN_STORAGE_KEY),
              10
            );
            return parsed === 1 ? 1 : 0;
          } catch (e) {
            return 0;
          }
        }

        function saveDesignIndex(index) {
          try {
            localStorage.setItem(DESIGN_STORAGE_KEY, String(index));
          } catch (e) {
            // ignore storage errors
          }
        }

        function updateDesignsLinkLabel() {
          if (!designsLink) return;
          const labelTarget =
            designsLink.querySelector(".nav-label") || designsLink;
          const text = "Designs (" + DESIGNS[currentDesignIndex].label + ")";

          if (designsLink.dataset.metroNavInitialized === "true") {
            const badge = designsLink.querySelector(".line-badge");
            const match = text.match(/^(\S)([\s\S]*)$/);
            if (badge && match) {
              badge.textContent = match[1].toUpperCase();
              labelTarget.textContent = match[2];
              labelTarget.dataset.originalText = text;
              designsLink.setAttribute("aria-label", text);
              return;
            }
          }

          labelTarget.textContent = text;
        }

        function applyDesign(index) {
          currentDesignIndex = index;
          const design = DESIGNS[index].name;
          document.documentElement.setAttribute("data-design", design);
          updateDesignsLinkLabel();
          document.dispatchEvent(
            new CustomEvent("site-design-change", { detail: { design } })
          );
        }

        document.addEventListener("DOMContentLoaded", function () {
          designsLink = document.getElementById("designs-link");
          applyDesign(getStoredDesignIndex());

          if (!designsLink) return;

          designsLink.addEventListener("click", function (event) {
            event.preventDefault();
            const nextIndex = (currentDesignIndex + 1) % DESIGNS.length;
            applyDesign(nextIndex);
            saveDesignIndex(nextIndex);
          });
        });
      })();
    </script>

    <script>
      (function () {
        const headingLines = {
          a: { color: "#0072bc", fg: "#ffffff" },
          b: { color: "#eb131b", fg: "#ffffff" },
          c: { color: "#58a738", fg: "#ffffff" },
          d: { color: "#a05da5", fg: "#ffffff" },
          e: { color: "#fdb913", fg: "#111111" },
          k: { color: "#da3d84", fg: "#ffffff" },
          g: { color: "#fc4c02", fg: "#ffffff" },
          j: { color: "#adb8bf", fg: "#111111" },
        };

        const headingFallbackOrder = [
          headingLines.a,
          headingLines.b,
          headingLines.c,
          headingLines.d,
          headingLines.e,
          headingLines.k,
          headingLines.g,
          headingLines.j,
        ];

        const pageLineRules = [
          { pattern: /^\/books(?:\/|$)/, line: "a" },
          { pattern: /^\/events(?:\/|$)/, line: "b" },
          { pattern: /^\/games(?:\/|$)/, line: "c" },
          { pattern: /^\/ideas(?:\/|$)/, line: "d" },
        ];

        const headingTextLineRules = [
          { pattern: /books i've written|more writing|writing|random writings/i, line: "e" },
          { pattern: /book summaries|books i've read/i, line: "a" },
          { pattern: /timeline|events|where i've worked/i, line: "b" },
          { pattern: /board games|games/i, line: "c" },
          { pattern: /speaking|affiliations/i, line: "k" },
          { pattern: /ideas/i, line: "d" },
        ];

        function resolveHeadingLine(heading, index) {
          if (heading.closest(".brand-row")) {
            return headingLines.a;
          }

          const headingText = heading.textContent.trim();
          const textRule = headingTextLineRules.find((rule) =>
            rule.pattern.test(headingText)
          );
          if (textRule) {
            return headingLines[textRule.line];
          }

          const pathname = window.location.pathname;
          const pageRule = pageLineRules.find((rule) =>
            rule.pattern.test(pathname)
          );
          if (pageRule) {
            return headingLines[pageRule.line];
          }

          return headingFallbackOrder[index % headingFallbackOrder.length];
        }

        function firstReadableTextNode(root) {
          const walker = document.createTreeWalker(
            root,
            NodeFilter.SHOW_TEXT,
            {
              acceptNode(node) {
                return node.nodeValue.trim()
                  ? NodeFilter.FILTER_ACCEPT
                  : NodeFilter.FILTER_REJECT;
              },
            }
          );

          return walker.nextNode();
        }

        function wrapHeadingInitial(heading, index) {
          if (heading.dataset.metroInitialized === "true") return;

          const textNode = firstReadableTextNode(heading);
          if (!textNode) return;

          const match = textNode.nodeValue.match(/^(\s*)(\S)([\s\S]*)$/);
          if (!match) return;

          const originalHeadingText = heading.textContent.trim();
          const owningLink = textNode.parentElement
            ? textNode.parentElement.closest("a")
            : null;
          if (originalHeadingText) {
            heading.setAttribute("aria-label", originalHeadingText);
          }
          if (owningLink && owningLink.textContent.trim()) {
            owningLink.setAttribute("aria-label", owningLink.textContent.trim());
          }

          const line = resolveHeadingLine(heading, index);
          heading.style.setProperty("--heading-line-color", line.color);
          heading.style.setProperty("--heading-line-fg", line.fg);

          const marker = document.createElement("span");
          marker.className = "metro-heading-letter";
          marker.setAttribute("aria-hidden", "true");
          marker.dataset.originalLetter = match[2];

          const glyph = document.createElement("span");
          glyph.className = "metro-heading-letter-glyph";
          glyph.textContent = match[2].toUpperCase();
          marker.appendChild(glyph);

          const fragment = document.createDocumentFragment();
          if (match[1]) fragment.appendChild(document.createTextNode(match[1]));
          fragment.appendChild(marker);
          if (match[3]) fragment.appendChild(document.createTextNode(match[3]));

          textNode.parentNode.replaceChild(fragment, textNode);
          heading.dataset.metroInitialized = "true";
        }

        function unwrapHeadingInitials() {
          document.querySelectorAll(".metro-heading-letter").forEach((marker) => {
            marker.replaceWith(
              document.createTextNode(
                marker.dataset.originalLetter || marker.textContent
              )
            );
          });

          document
            .querySelectorAll("[data-metro-initialized='true']")
            .forEach((heading) => {
              heading.dataset.metroInitialized = "false";
              heading.style.removeProperty("--heading-line-color");
              heading.style.removeProperty("--heading-line-fg");
            });
        }

        function syncHeadingDesign() {
          if (document.documentElement.dataset.design === "metro") {
            document
              .querySelectorAll(".site-main h1, .site-main h2, .brand-row h1")
              .forEach(wrapHeadingInitial);
            wrapNavInitials();
          } else {
            unwrapHeadingInitials();
            unwrapNavInitials();
          }
        }

        function wrapNavInitials() {
          document.querySelectorAll(".simple-nav a").forEach((link) => {
            if (link.dataset.metroNavInitialized === "true") return;

            const label = link.querySelector(".nav-label");
            const badge = link.querySelector(".line-badge");
            if (!label || !badge) return;

            const text = label.textContent.trim();
            const match = text.match(/^(\S)([\s\S]*)$/);
            if (!match) return;

            link.setAttribute("aria-label", text);
            badge.dataset.originalLetter = badge.textContent;
            badge.textContent = match[1].toUpperCase();
            label.textContent = match[2];
            label.dataset.originalText = text;
            label.classList.add("nav-label-trimmed");
            link.dataset.metroNavInitialized = "true";
          });
        }

        function unwrapNavInitials() {
          document
            .querySelectorAll(".simple-nav a[data-metro-nav-initialized='true']")
            .forEach((link) => {
              const label = link.querySelector(".nav-label");
              const badge = link.querySelector(".line-badge");

              if (label && label.dataset.originalText) {
                label.textContent = label.dataset.originalText;
                delete label.dataset.originalText;
                label.classList.remove("nav-label-trimmed");
              }

              if (badge && badge.dataset.originalLetter) {
                badge.textContent = badge.dataset.originalLetter;
                delete badge.dataset.originalLetter;
              }

              link.removeAttribute("aria-label");
              link.dataset.metroNavInitialized = "false";
            });
        }

        document.addEventListener("DOMContentLoaded", function () {
          syncHeadingDesign();
        });

        document.addEventListener("site-design-change", syncHeadingDesign);
      })();
    </script>
  </body>
</html>
